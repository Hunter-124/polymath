# Native inference sub-engines, vendored and built from source with CUDA.
# Run: git submodule update --init --recursive
[submodule "third_party/llama.cpp"]
	path = third_party/llama.cpp
	url = https://github.com/ggml-org/llama.cpp.git
	shallow = true
[submodule "third_party/whisper.cpp"]
	path = third_party/whisper.cpp
	url = https://github.com/ggml-org/whisper.cpp.git
	shallow = true
[submodule "third_party/piper"]
	path = third_party/piper
	url = https://github.com/rhasspy/piper.git
	shallow = true
[submodule "third_party/hnswlib"]
	path = third_party/hnswlib
	url = https://github.com/nmslib/hnswlib.git
	shallow = true
[submodule "third_party/miniaudio"]
	path = third_party/miniaudio
	url = https://github.com/mackron/miniaudio.git
	shallow = true
