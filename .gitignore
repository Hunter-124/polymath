# Build
/build/
/out/
/install/
# packaged distributable bundles (output of scripts/package.ps1)
/dist/
*.obj
*.o
*.lib
*.pdb
*.exe
*.dll

# vcpkg
/vcpkg_installed/
/third_party/vcpkg/

# Externally-fetched submodule checkouts (run: git submodule update --init).
# (third_party/sqlite3 and third_party/sqlcipher are vendored amalgamations and
#  ARE committed — the latter provides the at-rest-encryption codec.)
/third_party/llama.cpp/
/third_party/whisper.cpp/
/third_party/piper/
/third_party/hnswlib/
/third_party/miniaudio/

# Runtime data (large / private)
/models/
/media/
/data/
/vectors/
/documents/
*.gguf
*.onnx
*.bin
*.db
*.db-wal
*.db-shm
*.sqlite

# IDE
/.vs/
/.vscode/
.idea/
CMakeSettings.json
CMakeUserPresets.json

# Misc
*.log

# Downloaded prebuilt Piper engine (fetched by scripts)
/third_party/piper-engine/

# Node dependencies + JS build output. The mobile app (app/) and relay
# (cloud/relay/) ARE tracked source; only their deps/build artifacts are ignored.
node_modules/
/app/dist/
/app/dev-dist/
/cloud/relay/dist/
*.tsbuildinfo

# Capacitor native shells (regenerated by `npx cap add`; not committed)
/app/android/
/app/ios/

# Stray local Qt install (build uses C:\Qt, not a repo copy)
/Qt/
