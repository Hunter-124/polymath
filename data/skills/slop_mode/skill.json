{
  "name": "slop_mode",
  "description": "Ambient YouTube + agent-session babysitting",
  "triggers": [
    "slop mode",
    "put something on and watch my agents",
    "background youtube and watch agents"
  ],
  "params": {
    "type": "object",
    "properties": {
      "topic": {
        "type": "string",
        "description": "YouTube search topic / vibe"
      }
    },
    "required": ["topic"]
  },
  "confirm": false,
  "steps": [
    {
      "kind": "tool",
      "tool": "youtube_search",
      "description": "Search YouTube for an ambient/background video: {topic}",
      "args": {
        "query": "{topic} lofi ambient background music",
        "max_results": 6
      }
    },
    {
      "kind": "tool",
      "tool": "ui_control",
      "description": "Autoplay the top ambient/background search result (hands-free)",
      "args": {
        "action": "spawn_surface",
        "type": "video",
        "title": "Ambient: {topic}",
        "args": {
          "videoId": "{{result:youtube_search.results.0.videoId}}",
          "title": "{{result:youtube_search.results.0.title}}"
        }
      }
    },
    {
      "kind": "tool",
      "tool": "agent_watch",
      "description": "Babysit open agent sessions with voice notify",
      "args": {
        "notify": "voice"
      }
    }
  ]
}
