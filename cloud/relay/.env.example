# ── Hearth relay configuration ──────────────────────────────────────────────
# Copy to `.env` (loaded by your process manager / `docker run --env-file`) or
# set these in your host's dashboard (Fly secrets, Render env vars). Nothing
# here is application data — only routing + home-auth knobs.

# TCP port the public HTTP/WS server listens on.
# (Fly/Render inject their own PORT; this is the local/dev default.)
PORT=8080

# ── Home authentication ─────────────────────────────────────────────────────
# The relay only authenticates HOMES (so nobody can impersonate one). It does
# NOT authenticate end-user devices — the gateway does that end-to-end.

# Trust-on-first-use. When true, the first secret seen for a given home_id is
# remembered in memory and required to match thereafter. Convenient for
# self-hosting; NOT durable across restarts. Leave false for a shared relay.
RELAY_OPEN=false

# Static allow-list of homes as JSON: { "<home_id>": "<secret>" }.
# Used when RELAY_OPEN=false. Generate strong, random secrets.
RELAY_HOMES={"home-abc123":"replace-with-a-long-random-secret"}

# Alternatively (or additionally) load homes from a JSON file of the same shape.
# The RELAY_HOMES env var overrides the file on key collisions.
# RELAY_HOMES_FILE=/etc/polymath/homes.json

# ── Tuning (all optional; sensible defaults shown) ───────────────────────────

# How long the relay waits for the home to answer a request before 504 (ms).
REQUEST_TIMEOUT_MS=30000

# Tunnel keepalive: ping the agent after this idle interval, drop it if no pong
# arrives within the pong timeout (ms).
PING_INTERVAL_MS=20000
PONG_TIMEOUT_MS=10000

# Max client request body the relay will buffer before replying 413 (bytes).
MAX_BODY_BYTES=10485760

# Per-home request rate limit (token bucket). Set RATE_LIMIT_PER_SEC=0 to disable.
RATE_LIMIT_PER_SEC=50
RATE_LIMIT_BURST=100

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
